## ROI Calculator

Build a data-driven business case for migration.

```python
from aws2lakehouse.roi_calculator import ROICalculator, AWSCurrentState, DatabricksProjectedState

# ── Define current AWS costs ──
aws = AWSCurrentState(
    emr_monthly=120_000,
    glue_monthly=35_000,
    s3_monthly=25_000,
    kinesis_monthly=15_000,
    step_functions_monthly=5_000,
    lambda_monthly=8_000,
    other_monthly=7_000,
    engineer_count=12,
    avg_engineer_monthly=18_000
)

# ── Define projected Databricks costs ──
databricks = DatabricksProjectedState(
    jobs_dbu_monthly=55_000,
    sql_warehouse_monthly=15_000,
    serverless_monthly=10_000,
    storage_monthly=18_000,
    other_monthly=6_000,
    engineer_count=7,
    avg_engineer_monthly=18_000,
    migration_investment=850_000,
    migration_months=6
)

# ── Calculate ROI ──
calc = ROICalculator(aws, databricks)
result = calc.calculate()

print(f"Monthly savings: ${result.monthly_savings:,.0f}")
print(f"Annual savings:  ${result.annual_savings:,.0f}")
print(f"Payback period:  {result.payback_months:.1f} months")
print(f"3-year net:      ${result.three_year_net:,.0f}")

# ── Generate executive summary ──
summary = calc.generate_executive_summary()
print(summary)  # Ready for stakeholder presentation
```

