## Testing & Validation

Automated validation of every migrated pipeline.

```python
from aws2lakehouse.validation import MigrationValidator

validator = MigrationValidator()

# ── Generate validation notebook for a single pipeline ──
notebook = validator.generate_validation_notebook(
    pipeline_name="trade_events",
    source_table="legacy_db.trades",           # Source (AWS)
    target_table="production.risk_bronze.trade_events",  # Target (Databricks)
    primary_key="trade_id",
    numeric_columns=["notional_amount", "pnl"],
    tolerance=0.001  # 0.1% acceptable difference
)
# Checks: row count, schema, aggregates (sum/avg), duplicates, null keys

# ── Batch validation (multiple tables at once) ──
batch_notebook = validator.generate_batch_validation_notebook([
    {"pipeline_name": "trades", "source_table": "legacy.trades",
     "target_table": "prod.risk_bronze.trades", "primary_key": "trade_id"},
    {"pipeline_name": "positions", "source_table": "legacy.positions",
     "target_table": "prod.risk_bronze.positions", "primary_key": "position_id"},
    {"pipeline_name": "market_data", "source_table": "legacy.market_data",
     "target_table": "prod.risk_bronze.market_data", "primary_key": "instrument_id"},
])

# ── Business rule validation ──
rules_sql = validator.generate_business_rule_tests(
    table="production.risk_bronze.trade_events",
    rules=[
        {"name": "notional_positive", "condition": "notional_amount > 0", "threshold": 0.99},
        {"name": "valid_currency", "condition": "currency IN ('USD','EUR','GBP')", "threshold": 0.98},
        {"name": "no_future_dates", "condition": "trade_date <= current_date()", "threshold": 1.0},
    ]
)

# ── Cutover checklist ──
checklist = validator.generate_cutover_checklist(
    pipeline_name="trade_events",
    domain="risk"
)
```

